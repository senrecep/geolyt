  "dependencies": {
    "@elysiajs/swagger": "^1.2.0",
    "@geolyt/core": "workspace:*",
    "@geolyt/jobs": "workspace:*",
    "@geolyt/shared": "workspace:*",
    "better-auth": "^1.1.0",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.2.0",
    "ioredis": "^5.4.0",
    "postgres": "^3.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.3"
  }
}
