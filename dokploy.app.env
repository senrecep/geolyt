# =============================================================================
# geolyt - Dokploy Application Stack Environment Variables
# =============================================================================
# Stack: docker-compose.app.dokploy.yml (or docker-compose.dokploy.yml)
# Services: api, web, jobs, firecrawl, playwright
#
# Copy this file, fill in real values, and paste the contents into the
# Dokploy UI > Environment tab for the app service.
# =============================================================================

# PostgreSQL (must match the Infra stack if using 2-stack deployment)
POSTGRES_USER=geolyt
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=geolyt

# Redis
REDIS_PASSWORD=change-me-to-a-strong-password
REDIS_MAXMEMORY=512mb

# Better Auth
BETTER_AUTH_SECRET=change-me-to-at-least-32-characters
BETTER_AUTH_URL=https://api.geolyt.io

# Public URLs
NEXT_PUBLIC_APP_URL=https://app.geolyt.io
NEXT_PUBLIC_GEOLYT_API_URL=https://api.geolyt.io
NEXT_PUBLIC_BETTER_AUTH_URL=https://api.geolyt.io
GEOLYT_API_URL=https://api.geolyt.io

# Dashboard API key (used by the Next.js server for internal calls)
GEOLYT_DASHBOARD_API_KEY=change-me-to-a-strong-api-key

# AI providers
GOOGLE_AI_API_KEY=
ANTHROPIC_API_KEY=

# Brand mention APIs
YOUTUBE_DATA_API_KEY=
WIKIPEDIA_USER_AGENT=geolyt/1.0 (contact@geolyt.io)

# Cloudflare R2 (report storage)
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
