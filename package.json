{
  "name": "geolyt",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter='*' dev",
    "build": "bun run --filter='*' build",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter='*' typecheck",
    "db:generate": "bun run --filter=@geolyt/api db:generate",
    "db:migrate": "bun run --filter=@geolyt/api db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "bun@1.3.11"
}
